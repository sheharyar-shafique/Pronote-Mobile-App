<?xml version="1.0" encoding="utf-8"?>
<!--
  Place at: android/app/src/main/res/xml/data_extraction_rules.xml
  Purpose: opt out of cloud + device-transfer backups for PHI/HIPAA compliance.
-->
<data-extraction-rules>
  <cloud-backup>
    <exclude domain="root" />
    <exclude domain="file" />
    <exclude domain="database" />
    <exclude domain="sharedpref" />
  </cloud-backup>
  <device-transfer>
    <exclude domain="root" />
    <exclude domain="file" />
    <exclude domain="database" />
    <exclude domain="sharedpref" />
  </device-transfer>
</data-extraction-rules>
