<!--
  After running `npm run add:android`, open
  android/app/src/main/AndroidManifest.xml and merge these
  permissions into the manifest (above the <application> tag).
-->

<!-- Network -->
<uses-permission android:name="android.permission.INTERNET" />
<uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

<!-- Microphone for dictation -->
<uses-permission android:name="android.permission.RECORD_AUDIO" />
<uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

<!-- Foreground service so dictation continues if the user switches apps -->
<uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
<uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
<uses-permission android:name="android.permission.WAKE_LOCK" />

<!-- File / media access for uploads (Android 13+ uses scoped media perms) -->
<uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
<uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

<!-- Push notifications (Android 13+) -->
<uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

<!-- Biometric auth -->
<uses-permission android:name="android.permission.USE_BIOMETRIC" />

<!-- Microphone is the only audio input we use; declare as a hardware feature
     (required:true means devices without a mic — like some tablets — won't see
     the app on Play Store, which is correct for a dictation app). -->
<uses-feature android:name="android.hardware.microphone" android:required="true" />

<!-- Camera permission INTENTIONALLY NOT DECLARED. The app currently doesn't
     use the camera anywhere. Adding android.permission.CAMERA to the manifest
     triggers Play Store's "permissions that require a privacy policy" warning
     and increases scrutiny without any user-visible benefit. If we later add
     image-attachment-from-camera, declare it here AND fill out the Play
     Console "Sensitive permissions" justification at the same time. -->

<!--
  Inside the <application> tag, also set:
    android:allowBackup="false"
    android:fullBackupContent="false"
    android:dataExtractionRules="@xml/data_extraction_rules"
  to keep PHI out of cloud backups (HIPAA).
-->
