# Local development env. `npm run dev` reads this file.
#
# Default: point at the deployed Render backend so you can test without also
# running the Node API locally. Comment that line and uncomment the localhost
# one below if you're running the backend on your machine on port 3001.
VITE_API_URL=https://pronote-ai-medical-scribe.onrender.com/api
# VITE_API_URL=http://localhost:3001/api

VITE_USE_API=true
